modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
BASE_PATH = "/"
# Firebase keys should be set in Netlify Environment Variables (VITE_ prefix)
# Do NOT put real keys here if you are deploying to Netlify / Vercel
# VITE_FIREBASE_API_KEY = ""
# VITE_FIREBASE_AUTH_DOMAIN = ""
# VITE_FIREBASE_PROJECT_ID = ""
# VITE_FIREBASE_STORAGE_BUCKET = ""
# VITE_FIREBASE_MESSAGING_SENDER_ID = ""
# VITE_FIREBASE_APP_ID = ""

# Only the ones below are safe / non-sensitive
VITE_FIREBASE_AUTH_DOMAIN = "spacexmembership-5cdc3.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "spacexmembership-5cdc3"
VITE_FIREBASE_STORAGE_BUCKET = "spacexmembership-5cdc3.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "373866019176"
VITE_FIREBASE_APP_ID = "1:373866019176:web:2df0df0cd94391760bbedd"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 3002

[[ports]]
localPort = 19742
externalPort = 3000
