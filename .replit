modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
BASE_PATH = "/"
VITE_FIREBASE_AUTH_DOMAIN = "spacexmembership-5cdc3.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "spacexmembership-5cdc3"
VITE_FIREBASE_STORAGE_BUCKET = "spacexmembership-5cdc3.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "373866019176"
VITE_FIREBASE_APP_ID = "1:373866019176:web:2df0df0cd94391760bbedd"
